# Anthropic API key - required
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for itinerary generation.
# Opus = best quality. Sonnet = faster/cheaper, usually fine.
ANTHROPIC_MODEL=claude-opus-4-5

# Max tokens for the final synthesis
MAX_TOKENS=8000

# Cap on web_search tool calls per itinerary (3-6 is a good range)
MAX_WEB_SEARCHES=6

# Database URL. Default is local SQLite.
# For Postgres: postgresql+asyncpg://user:pass@host:5432/itinera
DATABASE_URL=sqlite+aiosqlite:///./itinera.db

# Comma-separated list of allowed CORS origins
# (Pydantic-settings parses JSON arrays, so use that format here)
CORS_ORIGINS=["http://localhost:3000"]
