# Anthropic API key - required
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for itinerary generation.
# Opus = best quality. Sonnet = faster/cheaper, usually fine.
ANTHROPIC_MODEL=claude-opus-4-5

# Max tokens for the final synthesis
MAX_TOKENS=8000

# Cap on web_search tool calls per itinerary (3-6 is a good range)
MAX_WEB_SEARCHES=6

# Database URL.
# Local dev:  sqlite+aiosqlite:///./itinera.db
# Production: paste your Neon/Supabase/Railway Postgres connection string verbatim.
#             The app rewrites `postgres://` and `postgresql://` to use asyncpg
#             and translates `?sslmode=require` automatically.
# Example:    postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/itinera?sslmode=require
DATABASE_URL=sqlite+aiosqlite:///./itinera.db

# Allowed CORS origins. Two accepted formats:
#   JSON array:        ["http://localhost:3000","https://itinera.vercel.app"]
#   Comma-separated:   http://localhost:3000,https://itinera.vercel.app
# In Render/Fly dashboards the comma-separated form is friendlier.
CORS_ORIGINS=["http://localhost:3000"]

# Global daily request quota for the /generate endpoints. Auto-resets at
# 00:00 UTC. Set to 0 to disable rate limiting entirely.
# Manual reset / bump:
#   UPDATE rate_limits SET count = 0, notified_at = NULL WHERE id = 1;
DAILY_REQUEST_LIMIT=7

# Webhook to ping when the daily limit is hit. Leave unset to disable.
# Auto-detected: Discord (`discord.com/api/webhooks/...`) and Slack
# (`hooks.slack.com/...`). Anything else gets a generic JSON payload that
# works with ntfy.sh, Make, Zapier, or your own HTTP endpoint.
#
# Quickest setup (no signup): https://ntfy.sh/itinera-yourname — then install
# the ntfy app on your phone and subscribe to the same topic.
# NOTIFY_WEBHOOK_URL=https://ntfy.sh/itinera-yourname
