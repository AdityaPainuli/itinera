# Base URL of the FastAPI backend.
# Local dev:  http://localhost:8000
# Production: https://<your-render-service>.onrender.com
#
# Vercel: set this in Project Settings → Environment Variables for both
# Production and Preview. Anything prefixed with NEXT_PUBLIC_ is inlined into
# the client bundle at build time, so changes require a redeploy.
NEXT_PUBLIC_API_BASE=http://localhost:8000
